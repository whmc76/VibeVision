# VibeVision unified local configuration.
# Change ports here instead of editing application code or package scripts.

APP_NAME=VibeVision
ENVIRONMENT=development

LLM_PROVIDER=minimax
LLM_LOGIC_PROVIDER=minimax
LLM_PROMPT_PROVIDER=ollama
LLM_VISION_PROVIDER=minimax_mcp

API_HOST=127.0.0.1
API_PORT=18751
ADMIN_FRONTEND_HOST=127.0.0.1
ADMIN_FRONTEND_PORT=18742
ADMIN_CORS_ORIGINS=http://localhost:18742,http://127.0.0.1:18742

DATABASE_URL=sqlite:///./data/vibevision.db

OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=huihui_ai/qwen3.5-abliterated:9b
OLLAMA_LOGIC_MODEL=
OLLAMA_PROMPT_MODEL=huihui_ai/qwen3.5-abliterated:9b
OLLAMA_VISION_MAX_BYTES=8000000
OLLAMA_MAX_CONCURRENCY=1
GPU_IDLE_RELEASE_SECONDS=5

MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_MODEL=codex-MiniMax-M2.7
MINIMAX_LOGIC_MODEL=codex-MiniMax-M2.7
MINIMAX_PROMPT_MODEL=
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_VISION_TIMEOUT_SECONDS=60
MINIMAX_VISION_MAX_BYTES=8000000

COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8401
COMFYUI_ROOT=E:\ComfyUI_Feb
COMFYUI_START_SCRIPT=run_nvidia_gpu.bat
COMFYUI_MAX_CONCURRENCY=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLLER_MAX_WORKERS=4
COMFYUI_POLL_INTERVAL_SECONDS=3
COMFYUI_POLL_TIMEOUT_SECONDS=600
VITE_API_BASE_URL=http://localhost:18751
